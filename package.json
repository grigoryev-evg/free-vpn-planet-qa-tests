{
  "name": "free-vpn-planet-qa-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E automation for Free VPN Planet QA assignment",
  "scripts": {
    "test": "playwright test",
    "test:assignment": "playwright test --grep @assignment --project=chromium",
    "test:smoke": "playwright test --grep @smoke --project=chromium",
    "test:signup": "playwright test tests-e2e/tests/specs/signup.e2e.ts",
    "test:personal-ru": "playwright test tests-e2e/tests/specs/personal_vpn_ru.e2e.ts",
    "test:personal-en": "playwright test tests-e2e/tests/specs/personal_vpn_en.e2e.ts",
    "test:e2e-ui": "playwright test tests-e2e/tests/specs",
    "test:e2e-api": "playwright test tests-e2e/tests/specs/payment_contract.e2e.ts",
    "test:headed": "playwright test --headed",
    "test:list": "playwright test --list",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
